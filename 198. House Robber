
//Tabulation

class Solution {

    public int rob(int[] nums) {

        int n = nums.length;

        // If there is only one house,
        // then rob that house.
        if (n == 1)
            return nums[0];

        // dp[i] = Maximum money that can be robbed
        // from house 0 to house i.
        // its like the best choice made in the index of i 
        int[] dp = new int[n];

        // Base Case 1:
        // Only one house is available.
        dp[0] = nums[0];

        // Base Case 2:
        // Two adjacent houses are available.
        // We cannot rob both, so choose the one with greater value.
        dp[1] = Math.max(nums[0], nums[1]);

        // Fill the remaining DP array.
        for (int i = 2; i < n; i++) {

            // Rob current house.
            // Since we rob this house,
            // we must skip the previous house.
            int take = nums[i] + dp[i - 2];

            // Skip current house.
            // Take the best answer till previous house.
            int skip = dp[i - 1];

            // Store the better choice.
            dp[i] = Math.max(take, skip);
        }

        // The last cell contains the maximum money
        // that can be robbed from all houses.
        return dp[n - 1];
    }
}
